DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
ADMIN_IDS=1262304052361035857
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Cấu hình Supabase (Tùy chọn - Dùng để quản lý vô hạn node động)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# ==========================================
# CẤU HÌNH NODE - CHỌN 1 TRONG 3 CÁCH DƯỚI ĐÂY
# (Nếu cấu hình Supabase hợp lệ, bot sẽ tự động lấy từ database thay vì ở đây)
# ==========================================

# CÁCH 1: Dùng 1 dòng duy nhất (Khuyên dùng khi host trên Render vì dễ copy/paste)
# Định dạng: host:port:password:secure (Ngăn cách các node bằng dấu phẩy)
NODELINKS=host1:port1:pass1:false,host2:port2:pass2:true

# CÁCH 2: Dùng cấu hình dạng JSON (Cực kỳ linh hoạt)
NODES_JSON=[{"id":"NodeLink-1","host":"node1.example.com","port":2333,"authorization":"youshallnotpass","secure":false}]

# CÁCH 3: Cấu hình từng node riêng lẻ (Cách cũ)
NODE1_HOST=YOUR_HOST
NODE1_PORT=YOUR_PORT
NODE1_PASSWORD=Password_NodeLink
NODE1_SECURE=false
